# Copy to .env and fill in your credentials
# .env is gitignored and never committed

# Required: your API key
OPENAI_API_KEY=sk-xxx

# Optional: override for OpenAI-compatible providers
# OpenAI (default, leave OPENAI_BASE_URL unset):
#   SPIKE_MODEL=gpt-4o-mini
#
# DeepSeek:
#   OPENAI_BASE_URL=https://api.deepseek.com
#   SPIKE_MODEL=deepseek-chat
#
# DashScope (Qwen):
#   OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#   SPIKE_MODEL=qwen-plus
#
# OpenRouter:
#   OPENAI_BASE_URL=https://openrouter.ai/api/v1
#   SPIKE_MODEL=anthropic/claude-3.5-sonnet
#
# Moonshot (Kimi):
#   OPENAI_BASE_URL=https://api.moonshot.cn/v1
#   SPIKE_MODEL=moonshot-v1-8k

# OPENAI_BASE_URL=
# SPIKE_MODEL=gpt-4o-mini
