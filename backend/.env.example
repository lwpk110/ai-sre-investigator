# AI SRE Investigator — 后端环境变量
# 复制为 .env 并填入实际值

# ─── LLM 配置 ───
OPENAI_API_KEY=sk-xxx
# OpenAI 兼容 API base URL（留空使用 OpenAI 官方）
# MiniMax: https://api.minimax.chat/v1
# DeepSeek: https://api.deepseek.com
# DashScope: https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_BASE_URL=
LLM_MODEL=MiniMax-M3

# ─── 可观测性后端 ───
MIMIR_URL=http://mimir-gateway.infra-monitoring.svc.tendata.kube1:80/prometheus
LOKI_URL=http://loki-gateway.infra-monitoring.svc.tendata.kube1
TEMPO_URL=http://tempo-gateway.infra-monitoring.svc.tendata.kube1

# ─── 预算控制（ADR-004 §5.2）───
MAX_TOKENS_PER_SESSION=80000
MAX_TOOL_CALLS_PER_SESSION=25
MAX_SESSION_SECONDS=180

# ─── 缓存（ADR-004 §5.1）───
CACHE_MAXSIZE=512
CACHE_TTL_NEAR_REALTIME=30
CACHE_TTL_HISTORICAL=600

# ─── HTTP 客户端（ADR-005）───
HTTP_TIMEOUT_SECONDS=30.0
HTTP_MAX_RETRIES=2
